{
  "name": "nztechrally",
  "version": "2.1.1",
  "description": "Version control for nztechrally.nz",
  "main": "index.js",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prepare": "lefthook install",
    "start": "eleventy --serve",
    "build": "eleventy",
    "debug": "DEBUG=* eleventy",
    "lint": "biome check src",
    "format": "biome format --write src"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NZTechRally/nztechrally.git"
  },
  "keywords": [],
  "author": "Prae Songprasit <hi@praesongprasit.com>",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/NZTechRally/nztechrally/issues"
  },
  "homepage": "https://github.com/NZTechRally/nztechrally#readme",
  "dependencies": {
    "@11ty/eleventy": "^3.1.2",
    "luxon": "^3.7.2",
    "node-fetch": "^3.3.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "lefthook"
    ],
    "overrides": {
      "minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
      "liquidjs@<10.25.0": ">=10.25.0"
    }
  },
  "devDependencies": {
    "@11ty/eleventy-navigation": "^1.0.5",
    "@11ty/eleventy-plugin-bundle": "^3.0.7",
    "@11ty/eleventy-plugin-inclusive-language": "^1.0.3",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "@biomejs/biome": "^2.4.4",
    "clean-css": "^5.3.3",
    "lefthook": "^2.1.1",
    "terser": "^5.46.0"
  }
}
